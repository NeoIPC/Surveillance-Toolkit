#. type: Hash Value: tbl-abr-infection-rate n_footnote
#: reports/common.yaml:1
#, no-wrap
msgid "%s: The aggregated number of antibiotic resistant pathogens in all infections."
msgstr "%s: Die Gesamtzahl der antibiotikaresistenten Erreger bei allen Infektionen."

#. type: Hash Value: tbl-abr-infection-rate pooled_footnote
#: reports/common.yaml:1
#, no-wrap
msgid "%s: The resistant pathogen infection rate calculated across all infants from all departments."
msgstr "%s: Die Infektionsrate mit resistenten Erregern, berechnet für alle Kinder aus allen Abteilungen."

#. type: Hash Value: tbl-abr-infection-rate quartile_footnote
#: reports/common.yaml:1
#, no-wrap
msgid "%s, %s, %s: The quartiles (%s, %s and %s quantiles) of the resistant pathogen infection rates of the partner departments. These quartiles are only displayed when the number of departments contributing to the denominator is greater than or equal to five, and when the median number of expected infections with an agents is greater than or equal to one according to the pooled resistant pathogen infection rate."
msgstr "%s, %s, %s: Die Quartile (%s, %s und %s Quantile) der Infektionsraten mit resistenten Erregern in den Partnerabteilungen. Diese Quartile werden nur angezeigt, wenn die Anzahl der Abteilungen, die zum Nenner beitragen, größer oder gleich fünf ist und wenn die mittlere Anzahl der erwarteten Infektionen mit einem Erreger gemäß der gepoolten Infektionsrate mit resistenten Erregern größer oder gleich eins ist."

#. type: Hash Value: tbl-abr-infection-rate rate_denominator
#: reports/common.yaml:1
#, no-wrap
msgid "Number of infections where a pathogen was detected"
msgstr "Anzahl der Infektionen, bei denen ein Erreger nachgewiesen wurde"

#. type: Hash Value: tbl-abr-infection-rate rate_name
#: reports/common.yaml:1
#, no-wrap
msgid "Resistant pathogen infection rate"
msgstr "Infektionsrate mit resistente Pathogenen"

#. type: Hash Value: tbl-abr-infection-rate rate_numerator
#: reports/common.yaml:1
#, no-wrap
msgid "Number of antibiotic resistant pathogens in infections"
msgstr "Anzahl antibiotikaresistenter Erreger bei Infektionen"

#. type: Hash Value: tbl-abr-infection-rate tbl-cap
#: reports/common.yaml:1
#, no-wrap
msgid "Nosocomial infections with resistant pathogens"
msgstr "Nosokomiale Infektionen mit resistenten Erregern"

#. type: Hash Value: tbl-agent-per-infection-rate n_footnote
#: reports/common.yaml:1
#, no-wrap
msgid "%s: The aggregated number of infectious agents in all infections."
msgstr "%s: Die Gesamtzahl der Infektionserreger in allen Infektionen."

#. type: Hash Value: tbl-agent-per-infection-rate pooled_footnote
#: reports/common.yaml:1
#, no-wrap
msgid "%s: The Agent-per-Infection Rate calculated across all infants from all departments."
msgstr "%s: Die Erreger-pro-Infektion-Rate, berechnet für alle Kinder aus allen Abteilungen."

#. type: Hash Value: tbl-agent-per-infection-rate quartile_footnote
#: reports/common.yaml:1
#, no-wrap
msgid "%s, %s, %s: The quartiles (%s, %s and %s quantiles) of the Agent-per-Infection Rates of the partner departments. These quartiles are only displayed when the number of departments contributing to the denominator is greater than or equal to five, and when the median number of expected agents detected in infections is greater than or equal to one according to the pooled Agent-per-Infection Rate."
msgstr "%s, %s, %s: Die Quartile (%s, %s und %s Quantile) der Erreger-pro-Infektion-Raten der Partnerabteilungen. Diese Quartile werden nur angezeigt, wenn die Anzahl der Abteilungen, die zum Nenner beitragen, größer oder gleich fünf ist und wenn die mittlere Anzahl der erwarteten Erreger, die bei Infektionen nachgewiesen werden, gemäß der gepoolten Erreger-pro-Infektion-Rate größer oder gleich eins ist."

#. type: Hash Value: tbl-agent-per-infection-rate rate_denominator
#: reports/common.yaml:1
#, no-wrap
msgid "No of infections where an infectious agent was detected"
msgstr "Anzahl der Infektionen, bei denen ein Infektionserreger nachgewiesen wurde"

#. type: Hash Value: tbl-agent-per-infection-rate rate_name
#: reports/common.yaml:1
#, no-wrap
msgid "Agent-per-Infection Rate"
msgstr "Erreger-pro-Infektion-Rate"

#. type: Hash Value: tbl-agent-per-infection-rate rate_numerator
#: reports/common.yaml:1
#, no-wrap
msgid "No of infectious agents that were detected in infections"
msgstr "Anzahl der bei Infektionen nachgewiesenen Infektionserreger"

#. type: Hash Value: tbl-agent-per-infection-rate tbl-cap
#: reports/common.yaml:1
#, no-wrap
msgid "Infectious agents detected in nosocomial infections"
msgstr "Bei nosokomialen Infektionen nachgewiesene Infektionserreger"

