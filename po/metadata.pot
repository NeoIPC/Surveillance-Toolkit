msgstr ""

#, priority:200
msgctxt "trackedEntityAttributes/NEOIPC_PATIENT_ID/FORM_NAME"
msgid "NeoIPC patient identifier"
msgstr ""

#, priority:10
msgctxt "trackedEntityAttributes/NEOIPC_PATIENT_ID/DESCRIPTION"
msgid "Use this identifier to uniquely identify a patient in the system. Ideally use an unique random string of characters. If have a requirement to identify a patient you have entered here, you can use this identifier as the NeoIPC key for pseudonymization. NEVER use an identifier that is used anywhere else and that you do not fully control (e.g. do NOT use the patient id from your hospital information system)."
msgstr ""

#, priority:150
msgctxt "trackedEntityAttributes/NEOIPC_TEA_BIRTH_WEIGHT/NAME"
msgid "NeoIPC Patient Birth weight"
msgstr ""

#, priority:10
msgctxt "trackedEntityAttributes/NEOIPC_TEA_BIRTH_WEIGHT/SHORT_NAME"
msgid "NeoIPC Pat. BW"
msgstr ""

#, priority:200
msgctxt "trackedEntityAttributes/NEOIPC_TEA_BIRTH_WEIGHT/FORM_NAME"
msgid "Birth weight"
msgstr ""

#, priority:10
msgctxt "trackedEntityAttributes/NEOIPC_TEA_BIRTH_WEIGHT/DESCRIPTION"
msgid "The infant’s weight immediately after birth in grams. Typically this value is based on a measurement but in case the birth weigth is unknown or has a highly pathological value that does not reflect the maturity of the infant (e.g. hydrops fetalis) you can enter the birth weight that is estimated by the treating physician."
msgstr ""

#, priority:150
msgctxt "trackedEntityAttributes/NEOIPC_TEA_DELIVERY_MODE/NAME"
msgid "NeoIPC Patient Delivery mode"
msgstr ""

#, priority:10
msgctxt "trackedEntityAttributes/NEOIPC_TEA_DELIVERY_MODE/SHORT_NAME"
msgid "NeoIPC Pat. Delivery mode"
msgstr ""

#, priority:200
msgctxt "trackedEntityAttributes/NEOIPC_TEA_DELIVERY_MODE/FORM_NAME"
msgid "Delivery mode"
msgstr ""

#, priority:10
msgctxt "trackedEntityAttributes/NEOIPC_TEA_DELIVERY_MODE/DESCRIPTION"
msgid "The mode of the infant's delivery. This can be either vaginal (including assisted vaginal delivery), elective caesarean section or emergency caesarean section."
msgstr ""

#, priority:150
msgctxt "trackedEntityAttributes/NEOIPC_TEA_GEST_AGE/NAME"
msgid "NeoIPC Patient Gestational age"
msgstr ""

#, priority:10
msgctxt "trackedEntityAttributes/NEOIPC_TEA_GEST_AGE/SHORT_NAME"
msgid "NeoIPC Pat. GA"
msgstr ""

#, priority:200
msgctxt "trackedEntityAttributes/NEOIPC_TEA_GEST_AGE/FORM_NAME"
msgid "Gestational age (weeks and days e.g. 25+4) "
msgstr ""

#, priority:10
msgctxt "trackedEntityAttributes/NEOIPC_TEA_GEST_AGE/DESCRIPTION"
msgid "The gestational age, expressed in completed weeks and days (e.g., 25 weeks and 4 days: 25+4) at the time of birth. Typically this refers to the gestational age as it was calculated or estimated by the mother's obstetrician but where this is not available (e.g. in unobserved pregnancies) the gestational age assesed by the treating physician (e.g. via the Ballard score) may be recorded."
msgstr ""

#, priority:150
